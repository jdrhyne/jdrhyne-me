---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('thoughts');
const sortedPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Group posts by year
const postsByYear = sortedPosts.reduce((acc, post) => {
  const year = new Date(post.data.date).getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof sortedPosts>);

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<Layout title="Thoughts" description="All thoughts and writings">
  <h1>Thoughts</h1>
  <p class="subtitle">All posts, chronologically.</p>

  <hr />

  {years.length > 0 ? (
    <div class="posts">
      {years.map(year => (
        <section class="year-group">
          <h2 class="year">{year}</h2>
          <ul class="post-list">
            {postsByYear[year].map(post => (
              <li class="post">
                <div class="post-header">
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                  <a href={`/thoughts/${post.slug}`} class="title">{post.data.title}</a>
                </div>
                {post.data.description && (
                  <p class="excerpt">{post.data.description}</p>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  ) : (
    <p class="empty">No posts yet.</p>
  )}
</Layout>

<style>
  h1 {
    margin-bottom: var(--space-xs);
  }

  .subtitle {
    color: var(--muted);
    margin-bottom: 0;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .year-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .year {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--muted);
    margin: 0;
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--border);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .post {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-header {
    display: flex;
    gap: var(--space-sm);
    align-items: baseline;
  }

  .post time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    min-width: 4rem;
    flex-shrink: 0;
  }

  .post .title {
    font-weight: 600;
    text-decoration: none;
  }

  .post .title:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  .post .excerpt {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0;
    padding-left: calc(4rem + var(--space-sm));
  }

  .empty {
    color: var(--muted);
    font-style: italic;
  }
</style>
