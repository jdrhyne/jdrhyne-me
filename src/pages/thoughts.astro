---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('thoughts');
const sortedPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Writing" description="All posts">
  <h1>Writing</h1>

  <ul class="posts">
    {sortedPosts.map(post => (
      <li>
        <a href={`/thoughts/${post.slug}`}>{post.data.title}</a>
        <span class="date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
      </li>
    ))}
  </ul>
</Layout>

<style>
  h1 { margin-bottom: 1.5rem; }

  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .posts li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--light);
  }

  .posts li:last-child { border-bottom: none; }

  .posts a { text-decoration: none; }
  .posts a:hover { text-decoration: underline; }

  .date {
    font-size: 0.85rem;
    color: var(--gray);
    flex-shrink: 0;
  }
</style>
