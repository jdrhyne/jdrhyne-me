---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';
import { config } from '../config';

const allPosts = await getCollection('thoughts');
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latestPost = sortedPosts[0];
const olderPosts = sortedPosts.slice(1);

const { Content } = await latestPost.render();
---

<Layout title={config.title} description={config.description}>
  <section class="intro">
    <h1>JONATHAN RHYNE</h1>
    <p>Code, curiosity, and continuous growth.</p>
  </section>

  <hr />

  {latestPost && (
    <article class="latest">
      <time>{new Date(latestPost.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
      <div class="content">
        <Content />
      </div>
      <a href={`/thoughts/${latestPost.slug}`} class="permalink">Permalink →</a>
    </article>
  )}

  {olderPosts.length > 0 && (
    <section class="older">
      <h3>OLDER POSTS</h3>
      {olderPosts.map(post => (
        <a href={`/thoughts/${post.slug}`} class="post">
          <span class="title">{post.data.title}</span>
          <span class="date">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
        </a>
      ))}
    </section>
  )}
</Layout>

<style>
  .intro { margin-bottom: 1.5rem; }
  .intro h1 { margin-bottom: 0.5rem; }
  .intro p { color: var(--gray); margin: 0; }

  .latest { margin: 2.5rem 0; }
  .latest time { font-size: 0.85rem; color: var(--gray); display: block; margin-bottom: 1rem; }

  .content { margin-bottom: 1.5rem; }

  .permalink { font-size: 0.85rem; color: var(--gray); text-decoration: none; }
  .permalink:hover { color: var(--black); }

  .older { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--light); }
  .older h3 { font-size: 0.9rem; margin-bottom: 1rem; color: var(--gray); }

  .post {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    text-decoration: none;
  }
  .post:hover .title { text-decoration: underline; }
  .date { font-size: 0.85rem; color: var(--gray); }
</style>
