---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';
import { config } from '../config';

const allPosts = await getCollection('thoughts');
const sortedPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title={config.title} description={config.description}>
  <p class="intro">{config.author.bio}</p>

  <h2>Writing</h2>
  <ul class="posts">
    {sortedPosts.map(post => (
      <li>
        <a href={`/thoughts/${post.slug}`}>{post.data.title}</a>
        <span class="date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .intro {
    margin-bottom: 2rem;
    color: var(--gray);
  }

  h2 { margin-top: 0; }

  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .posts li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.4rem 0;
  }

  .posts a { text-decoration: none; }
  .posts a:hover { text-decoration: underline; }

  .date {
    font-size: 0.85rem;
    color: var(--gray);
    flex-shrink: 0;
  }
</style>
