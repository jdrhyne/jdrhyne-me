---
import Layout from '../../components/Layout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/thoughts/*.md');
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop()?.replace('.md', '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const { frontmatter, Content } = post;
---

<Layout 
  title={frontmatter.title} 
  description={frontmatter.description}
  type="article"
  publishedTime={frontmatter.date}
>
  <article class="post">
    <time>{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>

    <div class="content"><Content /></div>

    <hr />
    <footer><a href="/thoughts">← All posts</a></footer>
  </article>
</Layout>

<style>
  .post {
    max-width: 65ch;
  }

  time { 
    font-size: 0.85rem; 
    color: var(--gray); 
    display: block; 
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
  }

  .content { 
    margin-bottom: 2rem;
  }

  .content :global(h1:first-child) {
    margin-top: 0;
  }

  footer { padding-top: 1rem; }
  footer a { color: var(--gray); text-decoration: none; font-size: 0.9rem; }
  footer a:hover { color: var(--black); }
</style>
