---
import Layout from '../../components/Layout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/thoughts/*.md');
  
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop()?.replace('.md', '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const { frontmatter, Content } = post;

const pageTitle = frontmatter.title;
const publishedTime = frontmatter.date ? new Date(frontmatter.date).toISOString() : undefined;
---

<Layout 
  title={pageTitle} 
  description={frontmatter.description || frontmatter.excerpt}
  type="article"
  publishedTime={publishedTime}
>
  <article class="post">
    <header class="header">
      <time datetime={frontmatter.date}>
        {new Date(frontmatter.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && (
        <p class="description">{frontmatter.description}</p>
      )}
    </header>

    <hr />

    <div class="content">
      <Content />
    </div>

    <footer class="footer">
      <a href="/thoughts" class="back">← All thoughts</a>
    </footer>
  </article>
</Layout>

<style>
  .post {
    max-width: 100%;
  }

  .header {
    margin-bottom: var(--space-md);
  }

  .header time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .header h1 {
    margin-bottom: var(--space-sm);
  }

  .description {
    color: var(--muted);
    font-style: italic;
    margin: 0;
  }

  .content {
    margin-bottom: var(--space-lg);
  }

  /* Prose styles */
  .content :global(h2) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .content :global(h3) {
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .content :global(p) {
    margin-bottom: var(--space-sm);
  }

  .content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: var(--space-sm);
    margin: var(--space-md) 0;
    color: var(--muted);
    font-style: italic;
  }

  .content :global(pre) {
    background: #1a1a1a;
    color: #f5f5f5;
    padding: var(--space-sm);
    margin: var(--space-md) 0;
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: #f0f0f0;
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  .content :global(img) {
    margin: var(--space-md) 0;
    border-radius: 4px;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: var(--space-sm);
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-lg) 0;
  }

  .footer {
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
  }

  .back {
    font-size: 0.9rem;
    color: var(--muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--text);
  }
</style>
