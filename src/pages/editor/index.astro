---
import Layout from '../../components/Layout.astro';
import { isEditorEnabled, verifyToken } from '../../lib/editor/auth';

// Check if editor is enabled
if (!isEditorEnabled()) {
  return Astro.redirect('/404');
}

// Check authentication
const token = Astro.cookies.get('editor-token')?.value;
if (!token || !verifyToken(token)) {
  return Astro.redirect('/editor/login');
}
---

<Layout title="Editor | JDR" description="Secret editor" showSidebar={false}>
  <div id="editor-root"></div>
  
  <script>
    import { EditorApp } from '../../components/editor/EditorApp';
    import React from 'react';
    import ReactDOM from 'react-dom/client';
    
    const root = ReactDOM.createRoot(document.getElementById('editor-root')!);
    root.render(React.createElement(EditorApp));
  </script>
</Layout>

<style>
  #editor-root {
    min-height: calc(100vh - 80px); /* Account for header */
    background: var(--color-background);
  }
</style>