---
import EditorLayout from '../../components/EditorLayout.astro';
import EditorClient from '../../components/editor/EditorClient.tsx';
import { isEditorEnabled, verifyToken } from '../../lib/editor/auth';

// Check if editor is enabled
if (!isEditorEnabled()) {
  return Astro.redirect('/404');
}

// Check authentication
const token = Astro.cookies.get('editor-token')?.value;
if (!token || !verifyToken(token)) {
  return Astro.redirect('/editor/login');
}
---

<EditorLayout title="Editor | JDR" description="Secret editor">
  <EditorClient client:only="react" />
</EditorLayout>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
</style>