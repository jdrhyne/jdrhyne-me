---
import Layout from '../components/Layout.astro';
import { config } from '../config';
---

<Layout title="About" description={`About ${config.author.name}`}>
  <h1>ABOUT</h1>

  <p>
    Co-founder & CEO of <a href="https://nutrient.io">Nutrient</a>. 
    We build document tools for developers.
  </p>

  <p>
    Previously grew PSPDFKit from a weekend project into the 
    industry-standard PDF SDK. Lawyer by training, engineer at heart.
  </p>

  <p>
    North Carolina. Soccer, astrophotography, Leica.
  </p>

  <hr />

  <p><a href={`mailto:${config.social.email}`}>Get in touch</a></p>
</Layout>

<style>
  h1 { margin-bottom: 2rem; }
</style>
