---
import Layout from '../components/Layout.astro';
import { config } from '../config';
---

<Layout title="About" description={`About ${config.author.name}`}>
  <h1>About</h1>

  <p>
    I'm Jonathan—co-founder & CEO of <a href="https://nutrient.io">Nutrient</a>, 
    where we build document tools for developers. Previously grew PSPDFKit from 
    a weekend project into the industry-standard PDF SDK.
  </p>

  <p>
    Lawyer by training, engineer at heart. Based in North Carolina.
  </p>

  <h2>Elsewhere</h2>
  <ul>
    <li><a href={config.social.github}>GitHub</a></li>
    <li><a href={config.social.twitter}>X</a></li>
    <li><a href={config.social.linkedin}>LinkedIn</a></li>
    <li><a href={`mailto:${config.social.email}`}>{config.social.email}</a></li>
  </ul>
</Layout>
