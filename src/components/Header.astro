---
const isHome = Astro.url.pathname === '/';
---

<header>
  {isHome ? (
    <div class="intro">
      <h1>JONATHAN D. RHYNE</h1>
      <p>Code, curiosity, and continuous growth.</p>
    </div>
  ) : (
    <a href="/" class="logo">JDRHYNE</a>
  )}
  <nav>
    <a href="/thoughts">Writing</a>
    <a href="/about">About</a>
    <a href="/rss.xml">RSS</a>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .intro h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0 0 0.25rem 0;
  }

  .intro p {
    color: var(--gray);
    margin: 0;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  nav { 
    display: flex; 
    gap: 1.5rem; 
    font-size: 0.9rem;
    padding-top: 0.35rem;
  }
  nav a { text-decoration: none; color: var(--gray); }
  nav a:hover { color: var(--black); }
</style>
