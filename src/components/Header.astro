---
import { config } from '../config';
---

<header class="header">
  <a href="/" class="logo">JDRHYNE_</a>
  <div class="status">
    <span class="label">PERSONAL BLOG</span>
  </div>
</header>

<nav class="nav">
  <a href="/thoughts">THOUGHTS</a>
  <a href="/about">ABOUT</a>
  <a href="/rss.xml">RSS</a>
</nav>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: var(--border);
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.25rem;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .logo:hover {
    background: none;
    color: var(--black);
  }

  .status {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--black);
    color: var(--white);
    padding: 0.2em 0.5em;
  }

  .nav {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-xs) 0;
    border-bottom: var(--border);
    font-size: 0.85rem;
  }

  .nav a {
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .nav a:hover {
    text-decoration: underline;
    background: none;
    color: var(--black);
  }

  @media (max-width: 480px) {
    .status {
      display: none;
    }
    
    .nav {
      gap: var(--space-sm);
      font-size: 0.8rem;
    }
  }
</style>
