---
const isHome = Astro.url.pathname === '/';
---

<header>
  {isHome ? (
    <div class="intro">
      <h1>JONATHAN D. RHYNE</h1>
      <p>Code, curiosity, and continuous growth.</p>
    </div>
  ) : (
    <a href="/" class="logo">JDRHYNE</a>
  )}
</header>

<hr />

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .intro h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0 0 0.25rem 0;
  }

  .intro p {
    color: var(--gray);
    margin: 0;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  hr {
    margin: 1.5rem 0 0 0;
  }
</style>
