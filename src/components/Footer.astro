---
import { config } from '../config';
---

<footer class="footer">
  <div class="links">
    {config.social.github && <a href={config.social.github}>GITHUB</a>}
    {config.social.twitter && <a href={config.social.twitter}>X</a>}
    {config.social.linkedin && <a href={config.social.linkedin}>LINKEDIN</a>}
    {config.social.email && <a href={`mailto:${config.social.email}`}>EMAIL</a>}
  </div>
  <div class="copy">
    © {new Date().getFullYear()} {config.author.name.toUpperCase()}
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-sm) 0;
    border-top: var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  .links {
    display: flex;
    gap: var(--space-sm);
  }

  .links a {
    text-decoration: none;
  }

  .links a:hover {
    text-decoration: underline;
    background: none;
    color: var(--black);
  }

  .copy {
    color: var(--black);
  }

  @media (max-width: 480px) {
    .footer {
      flex-direction: column;
      gap: var(--space-xs);
      text-align: center;
    }
  }
</style>
