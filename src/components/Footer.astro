---
import { config } from '../config';
---

<footer class="footer">
  <div class="links">
    {config.social.github && <a href={config.social.github}>GitHub</a>}
    {config.social.twitter && <a href={config.social.twitter}>X</a>}
    {config.social.linkedin && <a href={config.social.linkedin}>LinkedIn</a>}
    {config.social.email && <a href={`mailto:${config.social.email}`}>Email</a>}
  </div>
  <p class="copy">© {new Date().getFullYear()} {config.author.name}</p>
</footer>

<style>
  .footer {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .links {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .links a {
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--text);
  }

  .copy {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
  }
</style>
